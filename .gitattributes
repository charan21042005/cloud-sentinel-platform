# Force consistent line endings for all text files
* text=auto

# Explicitly set LF for script and code files (standard for Linux containers)
*.sh text eol=lf
*.py text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf
Makefile text eol=lf

# Denote binary files
*.png binary
*.jpg binary
*.ico binary
*.pdf binary
